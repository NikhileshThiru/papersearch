# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required by api-server, lib/db, and scripts)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/papersearch

# ── Semantic Scholar ──────────────────────────────────────────────────────────
# Optional — anonymous access works but is heavily rate-limited.
# Get a free key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your-api-key-here

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=3000

# Runtime environment — "development" relaxes the JWT_SECRET requirement
NODE_ENV=production

# JWT signing secret (required in production; auto-generated dev fallback used if omitted in development)
JWT_SECRET=replace-with-a-long-random-secret

# Pino log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL (optional — rate limiting falls back to in-memory if unset)
REDIS_URL=redis://HOST:6379

# ── Frontend (Vite dev server only) ───────────────────────────────────────────
# Port the Vite dev server listens on (default: 5173)
# PORT=5173

# URL prefix the frontend is served from (default: /)
# BASE_PATH=/

# Base URL the frontend uses to reach the API (default: /api)
# BASE_URL=http://localhost:3000/api
